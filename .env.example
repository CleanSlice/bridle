# ── Bridle Hub ────────────────────────────────
# Generate with: openssl rand -hex 32
BRIDLE_API_KEY=bridle-dev-key

# Must match the secret your app uses to sign browser JWTs.
JWT_SECRET=bridle-dev-secret

# Port the hub listens on.
PORT=3333

# CORS — comma-separated list of allowed origins, or '*' for any (dev only).
# Applied to BOTH the REST API and Socket.IO. Without this set, the hub
# falls back to '*'.
#   Production example:
# CORS_ORIGINS=https://your-site.com,https://app.your-site.com
CORS_ORIGINS=*

# ── For your runtime agent (.agent/agent.config.json) ──
# BRIDLE_URL=http://localhost:3333
# BRIDLE_BOT_ID=default
# BRIDLE_API_KEY=bridle-dev-key
