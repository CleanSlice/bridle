{
  "name": "@cleanslice/bridle",
  "version": "0.13.0",
  "description": "Embeddable web chat for Bridle — drop-in <script> or programmatic init.",
  "type": "module",
  "main": "./dist/bridle.mjs",
  "module": "./dist/bridle.mjs",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/bridle.js",
  "jsdelivr": "./dist/bridle.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bridle.mjs",
      "default": "./dist/bridle.mjs"
    },
    "./browser": "./dist/bridle.js",
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/bridle.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsc -p tsconfig.dts.json",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.2.0",
    "marked": "^15.0.0",
    "socket.io-client": "^4.7.5",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/dompurify": "^3.2.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.0.0"
  },
  "keywords": [
    "bridle",
    "cleanslice",
    "chat",
    "agent",
    "embed",
    "widget",
    "web-component",
    "socket.io"
  ],
  "license": "MIT",
  "homepage": "https://bridle.cleanslice.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CleanSlice/bridle.git",
    "directory": "sdk"
  }
}
